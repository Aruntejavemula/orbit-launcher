DATABASE_URL=postgresql://orbit:orbit@localhost:5432/orbitdb
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Observability
LOG_LEVEL=INFO
SLOW_QUERY_MS=200

# Backups (optional — only needed if using scripts/backup.py --upload)
BACKUP_DIR=backups
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=orbit-backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=       # leave blank for AWS S3; set for Cloudflare R2

# Restore testing (never point at production)
TARGET_DATABASE_URL=postgresql://orbit:orbit@localhost:5432/orbitdb_test
