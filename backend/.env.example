# Environment: dev | qa | prod (controls which .env.{ENV} file loads first)
APP_ENV=dev

DATABASE_URL=postgresql://orbit:orbit@localhost:5432/orbitdb
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
# Legacy fallback only; login uses 7-day session / 90-day remember cookies
JWT_EXPIRE_MINUTES=1440
# Web / PWA (GET /api/auth/google)
GOOGLE_CLIENT_ID=your-google-web-client-id
GOOGLE_CLIENT_SECRET=your-google-web-client-secret
# Must match a URI in Google Cloud Console; with Vite dev it is the frontend origin (proxy sends /api to backend)
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
# Desktop / Electron (GET /api/auth/google?platform=desktop)
GOOGLE_CLIENT_ID_DESKTOP=your-google-desktop-client-id
GOOGLE_CLIENT_SECRET_DESKTOP=your-google-desktop-client-secret
# Optional; defaults to GOOGLE_REDIRECT_URI when unset
# GOOGLE_REDIRECT_URI_DESKTOP=http://localhost:5173/api/auth/google/callback
FRONTEND_URL=http://localhost:5173
# Production (Railway) — web:
# FRONTEND_URL=https://www.remiolauncher.com
# GOOGLE_REDIRECT_URI=https://www.remiolauncher.com/api/auth/google/callback
# GOOGLE_CLIENT_ID_DESKTOP=...
# GOOGLE_CLIENT_SECRET_DESKTOP=...
# GOOGLE_REDIRECT_URI_DESKTOP=https://www.remiolauncher.com/api/auth/google/callback
# ENVIRONMENT=production
# FRONTEND_URLS=https://www.remiolauncher.com,https://remiolauncher.com
# Capacitor (add to production FRONTEND_URLS on Railway):
# https://localhost,capacitor://localhost,http://localhost

# Email (OTP, password reset, renewal reminders) — leave blank to log OTPs to console instead
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web Push (website PWA — Calendar → enable push + daily cron at 9:00 UTC)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@yourdomain.com

# Android FCM (Capacitor app — paste service account JSON as one line)
# Firebase Console → Project settings → Service accounts → Generate new private key
# Project ID from google-services.json (e.g. remio-9fa83)
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_JSON=
# Temporary: POST /api/push/test (instant test push, no cron). Set to 1 while testing Android; unset in prod when done.
# ALLOW_TEST_PUSH=1
# Android app: download google-services.json → frontend/android/app/google-services.json

# Redis (job queue for async email) — falls back to inline send if not set
REDIS_URL=redis://localhost:6379

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=
SLOW_QUERY_MS=200

# Backups (optional — only needed if using scripts/backup.py --upload)
BACKUP_DIR=backups
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=orbit-backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=       # leave blank for AWS S3; set for Cloudflare R2

# Restore testing (never point at production)
TARGET_DATABASE_URL=postgresql://orbit:orbit@localhost:5432/orbitdb_test
