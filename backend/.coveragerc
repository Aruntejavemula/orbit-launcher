[run]
branch = True
source = .
omit =
    alembic/*
    alembic/**/*
    scripts/*
    tests/*
    tests/**/*
    worker.py
    */__init__.py
    */conftest.py

[report]
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    \.\.\.
    pass

[xml]
output = coverage.xml
