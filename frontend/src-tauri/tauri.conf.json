{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Remio",
  "version": "0.1.0",
  "identifier": "com.remiolauncher.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Remio — your tool ecosystem",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https:; font-src 'self' https:; img-src 'self' data: https: blob:; connect-src 'self' https: wss:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "https://timestamp.digicert.com",
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/icon.ico"
      }
    },
    "macOS": {
      "signingIdentity": null
    },
    "category": "Utility",
    "shortDescription": "Track, manage, and launch all your subscriptions and tools in one place.",
    "longDescription": "Remio helps you organize your digital subscriptions and app ecosystem. Track renewal dates, monitor activity, and launch your tools — all from one beautiful dashboard.",
    "copyright": "Copyright 2026 Remio",
    "publisher": "Remio"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Aruntejavemula/orbit-launcher/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": ""
    }
  }
}
