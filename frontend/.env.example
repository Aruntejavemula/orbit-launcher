# Safe in the browser bundle (public):
# Web dev (Vite proxies /api → BACKEND_URL). Capacitor/Electron need absolute URL — see .env.capacitor
VITE_API_URL=/api

# Real sign-in (email, password, Google):
#   1. npm run dev
#   2. Start backend on :8000 (see backend/.env.example)
#   3. Set GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REDIRECT_URI in backend/.env
#      Redirect URI for local dev: http://localhost:5173/api/auth/google/callback

# Dev-server proxy only — never prefix with VITE_ (would leak into the client build):
BACKEND_URL=http://localhost:8000

# E2E against Railway (copy to .env.local, gitignored): proxies /api to prod/staging API.
# BACKEND_URL=https://www.remiolauncher.com
# Warning: Playwright register tests create @test.remio.app users in that database.
